{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openflow/schemas/visual-benchmark.schema.json",
  "title": "Visual Benchmark Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "benchmark_mode",
    "competitor_product",
    "required_modules",
    "scenarios"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "benchmark_mode": {
      "type": "string",
      "enum": ["placeholder", "reference_backed"]
    },
    "benchmark_input_mode": {
      "type": "string",
      "enum": ["missing", "reference_scenarios", "capture_url"]
    },
    "competitor_product": {
      "type": ["string", "null"]
    },
    "required_modules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "benchmark_matrix_contract": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "required_scenario_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "required_platform_profiles": {
          "type": "array",
          "items": { "type": "string", "enum": ["ios_phone", "android_phone", "mobile_h5", "desktop_web", "desktop_product_workbench"] }
        },
        "required_state_variants": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "max_average_pixel_diff_ratio": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "matrix_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["pass", "needs_follow_up"] },
          "detail": { "type": ["string", "null"] }
        }
      }
    },
    "matrix_status": {
      "type": "string",
      "enum": ["pass", "needs_follow_up"]
    },
    "report_file": {
      "type": ["string", "null"]
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "screenshot_evidence_mode"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "viewport": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": ["width", "height"],
            "properties": {
              "width": { "type": "number", "exclusiveMinimum": 0 },
              "height": { "type": "number", "exclusiveMinimum": 0 }
            }
          },
          "platform_profile": {
            "type": ["string", "null"],
            "enum": ["ios_phone", "android_phone", "mobile_h5", "desktop_web", "desktop_product_workbench", null]
          },
          "reference_image": {
            "type": ["string", "null"]
          },
          "screenshot_image": {
            "type": ["string", "null"]
          },
          "diff_metrics": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": ["status", "values", "thresholds"],
            "properties": {
              "status": {
                "type": "string",
                "enum": ["pass", "needs_follow_up"]
              },
              "issues": {
                "type": "array",
                "items": { "type": "string" }
              },
                "values": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "properties": {
                  "structural_similarity": { "type": ["number", "null"] },
                  "layout_shift_score": { "type": ["number", "null"] },
                  "pixel_diff_ratio": { "type": ["number", "null"] }
                }
              },
              "hotspots": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "row": { "type": "number", "minimum": 0 },
                    "col": { "type": "number", "minimum": 0 },
                    "changed_pixels": { "type": "number", "minimum": 0 },
                    "changed_ratio": { "type": "number", "minimum": 0 },
                    "x": { "type": "number", "minimum": 0 },
                    "y": { "type": "number", "minimum": 0 },
                    "width": { "type": "number", "minimum": 0 },
                    "height": { "type": "number", "minimum": 0 }
                  }
                }
              },
              "heatmap_file": {
                "type": ["string", "null"]
              },
              "thresholds": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "structural_similarity_min",
                  "layout_shift_score_max",
                  "pixel_diff_ratio_max"
                ],
                "properties": {
                  "structural_similarity_min": { "type": "number" },
                  "layout_shift_score_max": { "type": "number" },
                  "pixel_diff_ratio_max": { "type": "number" }
                }
              }
            }
          },
          "structure_checks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "status"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "status": { "type": "string", "enum": ["pass", "needs_follow_up"] },
                "detail": { "type": ["string", "null"] }
              }
            }
          },
          "token_checks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "status"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "status": { "type": "string", "enum": ["pass", "needs_follow_up"] },
                "detail": { "type": ["string", "null"] }
              }
            }
          },
          "state_evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "screenshot_image", "nodes_captured"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "label": { "type": ["string", "null"] },
                "screenshot_image": { "type": "string", "minLength": 1 },
                "nodes_captured": { "type": "number", "minimum": 0 },
                "expect_visual_change": { "type": "boolean" },
                "min_pixel_diff_ratio": { "type": ["number", "null"], "minimum": 0 },
                "reference_image": { "type": ["string", "null"] },
                "priority_score": { "type": ["number", "null"] },
                "priority_reason": { "type": ["string", "null"] },
                "source": { "type": ["string", "null"] },
                "workbench_state_type": {
                  "type": ["string", "null"],
                  "enum": ["detail_open", "active_filter", "selected_item", "bulk_select_mode", null]
                },
                "component_family": { "type": ["string", "null"] },
                "state_variant": {
                  "type": ["string", "null"],
                  "enum": ["hover", "active", "selected", "expanded", "focused", "dragged", "revealed", "refreshed", null]
                },
                "expect_motion": { "type": ["boolean", "null"] },
                "min_motion_changed_frames": { "type": ["number", "null"], "minimum": 0 },
                "frame_screenshot_images": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                },
                "state_visual_tokens": {
                  "type": ["object", "null"],
                  "additionalProperties": false,
                  "properties": {
                    "color_roles": {
                      "type": ["object", "null"],
                      "additionalProperties": { "type": "string", "minLength": 1 }
                    },
                    "shadow_strength_tiers": {
                      "type": "array",
                      "items": { "type": "string", "enum": ["subtle", "medium", "strong"] }
                    },
                    "transition_durations": {
                      "type": "array",
                      "items": { "type": "number", "minimum": 0 }
                    },
                    "transition_timing_functions": {
                      "type": "array",
                      "items": { "type": "string", "minLength": 1 }
                    },
                    "animation_durations": {
                      "type": "array",
                      "items": { "type": "number", "minimum": 0 }
                    },
                    "radius_values": {
                      "type": "array",
                      "items": { "type": "number", "minimum": 0 }
                    },
                    "border_widths": {
                      "type": "array",
                      "items": { "type": "number", "minimum": 0 }
                    },
                    "bottom_sheet_handle_present": {
                      "type": ["boolean", "null"]
                    },
                    "tabbar_active_state_present": {
                      "type": ["boolean", "null"]
                    }
                  }
                },
                "state_tags": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                }
              }
            }
          },
          "state_contract": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "required_workbench_states": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["detail_open", "active_filter", "selected_item", "bulk_select_mode"]
                }
              }
            }
          },
          "state_contract_checks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "status"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "status": { "type": "string", "enum": ["pass", "needs_follow_up"] },
                "detail": { "type": ["string", "null"] }
              }
            }
          },
          "state_family_contract": {
            "type": ["object", "null"],
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "required_variants": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["hover", "active", "selected", "expanded", "focused", "dragged", "revealed", "refreshed"] }
                },
                "max_pixel_diff_spread": { "type": "number", "minimum": 0 },
                "max_layout_shift_spread": { "type": "number", "minimum": 0 },
                "min_distinct_surface_colors": { "type": "number", "minimum": 0 },
                "min_distinct_shadow_strength_tiers": { "type": "number", "minimum": 0 },
                "required_timing_functions": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                },
                "max_radius_spread": { "type": "number", "minimum": 0 },
                "max_border_width_spread": { "type": "number", "minimum": 0 },
                "max_transition_duration_spread": { "type": "number", "minimum": 0 },
                "max_animation_duration_spread": { "type": "number", "minimum": 0 }
              }
            }
          },
          "state_family_checks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "status"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "status": { "type": "string", "enum": ["pass", "needs_follow_up"] },
                "detail": { "type": ["string", "null"] }
              }
            }
          },
          "state_transition_checks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "status"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "status": { "type": "string", "enum": ["pass", "needs_follow_up"] },
                "detail": { "type": ["string", "null"] },
                "compared_to": { "type": ["string", "null"], "enum": ["reference_state", "base_state", null] },
                "diff_metrics": {
                  "type": ["object", "null"],
                  "additionalProperties": false,
                  "properties": {
                    "structural_similarity": { "type": ["number", "null"] },
                    "layout_shift_score": { "type": ["number", "null"] },
                    "pixel_diff_ratio": { "type": ["number", "null"] }
                  }
                }
              }
            }
          },
          "motion_transition_checks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "status"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "status": { "type": "string", "enum": ["pass", "needs_follow_up"] },
                "detail": { "type": ["string", "null"] },
                "motion_profile": {
                  "type": ["object", "null"],
                  "additionalProperties": false,
                  "properties": {
                    "sampled_frames": { "type": ["number", "null"], "minimum": 0 },
                    "changed_frames": { "type": ["number", "null"], "minimum": 0 },
                    "peak_pixel_diff_ratio": { "type": ["number", "null"], "minimum": 0 },
                    "peak_layout_shift_score": { "type": ["number", "null"], "minimum": 0 }
                  }
                }
              }
            }
          },
          "layout_contract": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "expected_columns": { "type": "number", "exclusiveMinimum": 0 },
              "required_panels": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "workspace_patterns": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "header_with_split_workspace",
                    "sidebar_docked_left",
                    "filters_above_list",
                    "list_detail_master_detail",
                    "detail_docked_right",
                    "toolbar_over_workspace",
                    "compact_top_nav",
                    "bottom_tabbar_docked",
                    "bottom_sheet_over_content"
                  ]
                }
              },
              "anchor_relations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["from", "to", "relation"],
                  "properties": {
                    "id": { "type": "string", "minLength": 1 },
                    "from": { "type": "string", "minLength": 1 },
                    "to": { "type": "string", "minLength": 1 },
                    "relation": {
                      "type": "string",
                      "enum": ["left_of", "right_of", "above", "below", "aligned_top", "aligned_left"]
                    },
                    "gap_min": { "type": "number" },
                    "gap_max": { "type": "number" },
                    "tolerance": { "type": "number", "minimum": 0 }
                  }
                }
              },
              "min_sidebar_width": { "type": "number", "exclusiveMinimum": 0 },
              "min_main_width": { "type": "number", "exclusiveMinimum": 0 },
              "min_detail_width": { "type": "number", "exclusiveMinimum": 0 },
              "safe_area_top_panels": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "safe_area_bottom_panels": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "safe_area_tolerance": { "type": "number", "minimum": 0 },
              "keyboard_aware_panels": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "keyboard_clearance_min": { "type": "number", "minimum": 0 },
              "thumb_reach_primary_action_panels": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "thumb_reach_zone": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "properties": {
                  "min_y_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
                  "max_y_ratio": { "type": "number", "minimum": 0, "maximum": 1 }
                }
              },
              "alignment_grid_step": { "type": "number", "exclusiveMinimum": 0 },
              "alignment_grid_tolerance": { "type": "number", "minimum": 0 },
              "alignment_grid_panels": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          },
          "visual_token_contract": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "font_families_required": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "font_weights_required": {
                "type": "array",
                "items": { "type": "number" }
              },
              "text_size_range": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "properties": {
                  "min": { "type": "number", "exclusiveMinimum": 0 },
                  "max": { "type": "number", "exclusiveMinimum": 0 }
                }
              },
              "icon_density_range": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "properties": {
                  "min": { "type": "number", "minimum": 0 },
                  "max": { "type": "number", "minimum": 0 }
                }
              },
              "icon_size_range": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "properties": {
                  "min": { "type": "number", "minimum": 0 },
                  "max": { "type": "number", "minimum": 0 }
                }
              },
              "min_touch_target_size": {
                "type": ["number", "null"],
                "minimum": 0
              },
              "bottom_sheet_handle_required": {
                "type": ["boolean", "null"]
              },
              "tabbar_active_state_required": {
                "type": ["boolean", "null"]
              },
              "floating_primary_action_required": {
                "type": ["boolean", "null"]
              },
              "segmented_control_active_state_required": {
                "type": ["boolean", "null"]
              },
              "required_component_semantics": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "bottom_sheet",
                    "tab_bar",
                    "floating_primary_action",
                    "segmented_control",
                    "search_bar",
                    "snackbar",
                    "pull_to_refresh_indicator",
                    "loading_state",
                    "skeleton_state",
                    "error_state",
                    "search_active"
                  ]
                }
              },
              "required_platform_physics_profiles": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["ios_spring", "android_ripple", "mobile_h5_smooth"]
                }
              },
              "list_row_height_range": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "properties": {
                  "min": { "type": "number", "minimum": 0 },
                  "max": { "type": "number", "minimum": 0 }
                }
              },
              "toolbar_control_density_range": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "properties": {
                  "min": { "type": "number", "minimum": 0 },
                  "max": { "type": "number", "minimum": 0 }
                }
              },
              "detail_block_spacing_scale": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "properties": {
                  "base": { "type": "number", "exclusiveMinimum": 0 },
                  "allowed_multipliers": {
                    "type": "array",
                    "items": { "type": "number", "exclusiveMinimum": 0 }
                  },
                  "tolerance": { "type": "number", "minimum": 0 }
                }
              },
              "line_height_range": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "properties": {
                  "min": { "type": "number", "exclusiveMinimum": 0 },
                  "max": { "type": "number", "exclusiveMinimum": 0 }
                }
              },
              "letter_spacing_range": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "properties": {
                  "min": { "type": "number" },
                  "max": { "type": "number" }
                }
              },
              "radius_range": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "properties": {
                  "min": { "type": "number", "minimum": 0 },
                  "max": { "type": "number", "minimum": 0 }
                }
              },
              "border_width_range": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "properties": {
                  "min": { "type": "number", "minimum": 0 },
                  "max": { "type": "number", "minimum": 0 }
                }
              },
              "border_styles_required": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "border_weight_tiers_required": {
                "type": "array",
                "items": { "type": "string", "enum": ["hairline", "regular", "strong"] }
              },
              "color_roles": {
                "type": ["object", "null"],
                "additionalProperties": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "shadow_signatures_required": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "shadow_strength_tiers_required": {
                "type": "array",
                "items": { "type": "string", "enum": ["subtle", "medium", "strong"] }
              },
              "spacing_scale": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "properties": {
                  "base": { "type": "number", "exclusiveMinimum": 0 },
                  "allowed_multipliers": {
                    "type": "array",
                    "items": { "type": "number", "exclusiveMinimum": 0 }
                  },
                  "tolerance": { "type": "number", "minimum": 0 }
                }
              },
              "component_family_consistency": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "properties": {
                  "toolbar_controls": {
                    "type": ["object", "null"],
                    "additionalProperties": false,
                    "properties": {
                      "max_text_size_delta": { "type": "number", "minimum": 0 },
                      "max_line_height_delta": { "type": "number", "minimum": 0 },
                      "max_radius_delta": { "type": "number", "minimum": 0 },
                      "max_border_width_delta": { "type": "number", "minimum": 0 }
                    }
                  },
                  "list_rows": {
                    "type": ["object", "null"],
                    "additionalProperties": false,
                    "properties": {
                      "max_text_size_delta": { "type": "number", "minimum": 0 },
                      "max_line_height_delta": { "type": "number", "minimum": 0 },
                      "max_radius_delta": { "type": "number", "minimum": 0 },
                      "max_border_width_delta": { "type": "number", "minimum": 0 }
                    }
                  },
                  "detail_blocks": {
                    "type": ["object", "null"],
                    "additionalProperties": false,
                    "properties": {
                      "max_text_size_delta": { "type": "number", "minimum": 0 },
                      "max_line_height_delta": { "type": "number", "minimum": 0 },
                      "max_radius_delta": { "type": "number", "minimum": 0 },
                      "max_border_width_delta": { "type": "number", "minimum": 0 }
                    }
                  }
                }
              }
            }
          },
          "observed_layout": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "columns": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["id", "width"],
                  "properties": {
                    "id": { "type": "string", "minLength": 1 },
                    "width": { "type": "number", "exclusiveMinimum": 0 }
                  }
                }
              }
            }
          },
          "observed_visual_tokens": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "font_families": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "font_weights": {
                "type": "array",
                "items": { "type": "number" }
              },
              "text_sizes": {
                "type": "array",
                "items": { "type": "number", "exclusiveMinimum": 0 }
              },
              "icon_density_values": {
                "type": "array",
                "items": { "type": "number", "minimum": 0 }
              },
              "icon_size_values": {
                "type": "array",
                "items": { "type": "number", "minimum": 0 }
              },
              "touch_target_sizes": {
                "type": "array",
                "items": { "type": "number", "minimum": 0 }
              },
              "safe_area_top_inset": {
                "type": ["number", "null"],
                "minimum": 0
              },
              "safe_area_bottom_inset": {
                "type": ["number", "null"],
                "minimum": 0
              },
              "keyboard_inset_bottom": {
                "type": ["number", "null"],
                "minimum": 0
              },
              "bottom_sheet_handle_present": {
                "type": ["boolean", "null"]
              },
              "tabbar_active_state_present": {
                "type": ["boolean", "null"]
              },
              "floating_primary_action_present": {
                "type": ["boolean", "null"]
              },
              "segmented_control_active_state_present": {
                "type": ["boolean", "null"]
              },
