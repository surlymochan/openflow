{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openflow/schemas/workflow.schema.json",
  "title": "XFlow Workflow Definition",
  "type": "object",
  "required": ["name", "version", "track", "requires", "phases"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "track": { "type": "string", "enum": ["lite", "heavy"] },
    "parallel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_agents": { "type": "integer", "minimum": 1, "maximum": 16 },
        "policy": { "type": "string", "enum": ["weighted", "fixed"] }
      }
    },
    "requires": {
      "type": "object",
      "properties": {
        "agentos_http": { "type": "boolean" },
        "agentos_bin": { "type": "boolean" },
        "gh": { "type": "boolean" },
        "pencil": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "required"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "catalog_ref": { "type": "integer", "minimum": 1, "maximum": 27 },
          "required": { "type": "boolean" },
          "condition": {
            "type": "object",
            "description": "Skip phase unless condition met",
            "properties": {
              "input_field": { "type": "string" },
              "equals": {}
            }
          },
          "atoms": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id"],
              "properties": {
                "id": { "type": "string" },
                "with": { "type": "object" },
                "parallel_group": { "type": "string" },
                "parallel_weight": { "type": "integer", "minimum": 1, "maximum": 16 }
              }
            }
          },
          "preconditions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "phase_artifact": { "type": "string" },
                "predicate": { "type": "string", "enum": ["exists", "nonempty", "equals", "truthy"] },
                "value": {}
              }
            }
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path"],
              "properties": {
                "path": { "type": "string" },
                "optional": { "type": "boolean", "default": false }
              }
            }
          },
          "gate": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["deterministic", "artifact-verify", "llm-judge", "human", "skip"] },
              "atom": { "type": "string" },
              "with": { "type": "object" },
              "on_fail": { "type": "string", "enum": ["stop", "retry", "advance-with-warning"] }
            }
          }
        }
      }
    }
  }
}
